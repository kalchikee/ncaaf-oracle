# NCAAF Oracle v4.1 — Environment Variables

# collegefootballdata.com API key (free at https://collegefootballdata.com/key)
CFBD_API_KEY=your_cfbd_api_key_here

# The-Odds-API key (free tier at https://the-odds-api.com)
ODDS_API_KEY=your_odds_api_key_here

# Discord webhook URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL

# Cache TTL in hours (default: 4)
CACHE_TTL_HOURS=4

# Current season year
SEASON_YEAR=2025
